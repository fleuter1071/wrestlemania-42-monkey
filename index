<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>WrestleMania 42</title>
  <style>
    :root {
      --bg: #050505;
      --panel: rgba(255, 255, 255, 0.06);
      --panel-strong: rgba(255, 255, 255, 0.09);
      --border: rgba(255, 255, 255, 0.12);
      --text: #ffffff;
      --muted: rgba(255, 255, 255, 0.72);
      --soft: rgba(255, 255, 255, 0.5);
      --red: #e11d48;
      --red-bright: #ff365f;
      --blue: #3b82f6;
      --shadow: 0 30px 80px rgba(0, 0, 0, 0.45);
      --radius-xl: 32px;
      --radius-lg: 24px;
      --radius-md: 18px;
      --max: 1200px;
    }

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      font-family: Inter, Arial, Helvetica, sans-serif;
      background:
        radial-gradient(circle at top, rgba(225, 29, 72, 0.24), transparent 32%),
        radial-gradient(circle at bottom, rgba(59, 130, 246, 0.18), transparent 28%),
        var(--bg);
      color: var(--text);
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    .container {
      width: min(calc(100% - 32px), var(--max));
      margin: 0 auto;
    }

    .topbar {
      position: sticky;
      top: 0;
      z-index: 20;
      backdrop-filter: blur(16px);
      background: rgba(5, 5, 5, 0.72);
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .topbar-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      min-height: 72px;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 12px;
      font-weight: 900;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .brand-badge {
      display: grid;
      place-items: center;
      width: 42px;
      height: 42px;
      border-radius: 14px;
      background: linear-gradient(135deg, var(--red-bright), #991b1b);
      box-shadow: 0 14px 30px rgba(225, 29, 72, 0.35);
      font-size: 0.95rem;
    }

    .nav {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .nav a {
      color: var(--muted);
      font-size: 0.92rem;
      padding: 10px 14px;
      border-radius: 999px;
      transition: 0.2s ease;
    }

    .nav a:hover {
      background: rgba(255, 255, 255, 0.06);
      color: var(--text);
    }

    .hero {
      padding: 56px 0 28px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 40px;
      align-items: center;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 16px;
      border-radius: 999px;
      background: rgba(225, 29, 72, 0.12);
      border: 1px solid rgba(225, 29, 72, 0.28);
      color: #ffb0bf;
      font-size: 0.78rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.22em;
    }

    h1 {
      margin: 18px 0 0;
      font-size: clamp(3rem, 8vw, 6rem);
      line-height: 0.95;
      text-transform: uppercase;
      letter-spacing: -0.04em;
    }

    .accent {
      color: var(--red-bright);
      text-shadow: 0 0 28px rgba(255, 54, 95, 0.3);
    }

    .hero p.lead {
      margin: 22px 0 0;
      max-width: 720px;
      font-size: 1.12rem;
      line-height: 1.8;
      color: var(--muted);
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      margin-top: 30px;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      min-height: 50px;
      padding: 0 22px;
      border: 1px solid transparent;
      border-radius: 18px;
      font-weight: 900;
      font-size: 0.86rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      transition: transform 0.18s ease, background 0.18s ease, border-color 0.18s ease;
      cursor: pointer;
    }

    .btn:hover {
      transform: translateY(-1px);
    }

    .btn-primary {
      background: linear-gradient(135deg, var(--red-bright), #be123c);
      box-shadow: 0 18px 40px rgba(225, 29, 72, 0.28);
    }

    .btn-secondary {
      background: rgba(255, 255, 255, 0.05);
      border-color: var(--border);
      color: var(--text);
    }

    .hero-card {
      position: relative;
      padding: 26px;
      border-radius: var(--radius-xl);
      background: linear-gradient(180deg, rgba(255,255,255,0.07), rgba(255,255,255,0.04));
      border: 1px solid var(--border);
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .hero-card::before {
      content: "";
      position: absolute;
      inset: -40% auto auto -10%;
      width: 220px;
      height: 220px;
      background: radial-gradient(circle, rgba(255, 54, 95, 0.18), transparent 70%);
      pointer-events: none;
    }

    .hero-card-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 18px;
    }

    .hero-card-top p {
      margin: 0;
      color: var(--soft);
      text-transform: uppercase;
      letter-spacing: 0.24em;
      font-size: 0.75rem;
      font-weight: 800;
    }

    .live-pill {
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(225, 29, 72, 0.12);
      border: 1px solid rgba(225, 29, 72, 0.24);
      color: #ffb4c2;
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      font-weight: 900;
    }

    .detail-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 14px;
    }

    .detail-box,
    .highlight-card,
    .match-card,
    .info-panel,
    .cta-panel {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      backdrop-filter: blur(14px);
    }

    .detail-box {
      padding: 18px;
      min-height: 120px;
    }

    .label {
      margin: 0;
      font-size: 0.76rem;
      color: var(--soft);
      text-transform: uppercase;
      letter-spacing: 0.22em;
      font-weight: 800;
    }

    .value {
      margin: 12px 0 0;
      font-size: 1.1rem;
      font-weight: 800;
      line-height: 1.35;
    }

    .section {
      padding: 28px 0;
    }

    .highlights-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 18px;
    }

    .highlight-card {
      padding: 24px;
    }

    .highlight-bar {
      width: 48px;
      height: 8px;
      border-radius: 999px;
      background: linear-gradient(90deg, var(--red-bright), #f97316);
      margin-bottom: 18px;
    }

    .highlight-card p {
      margin: 0;
      color: var(--muted);
      line-height: 1.75;
    }

    .section-head {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 20px;
      margin-bottom: 24px;
    }

    .section-head h2 {
      margin: 10px 0 0;
      font-size: clamp(2rem, 4vw, 3rem);
      line-height: 1;
      text-transform: uppercase;
      letter-spacing: -0.03em;
    }

    .section-head p {
      max-width: 520px;
      color: var(--soft);
      line-height: 1.7;
      margin: 0;
    }

    .match-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 18px;
    }

    .match-card {
      padding: 22px;
      box-shadow: var(--shadow);
    }

    .match-top {
      display: flex;
      align-items: center;
      gap: 14px;
      margin-bottom: 18px;
    }

    .match-top .tag {
      color: #ffb4c2;
      font-weight: 900;
      font-size: 0.78rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .match-top .line {
      height: 1px;
      flex: 1;
      background: rgba(255, 255, 255, 0.1);
    }

    .match-card h3 {
      margin: 0;
      font-size: 1.6rem;
      line-height: 1.15;
    }

    .versus {
      margin-top: 18px;
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      gap: 12px;
      align-items: center;
      padding: 18px;
      border-radius: 20px;
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .competitor {
      font-weight: 800;
      font-size: 1.08rem;
      text-align: center;
      line-height: 1.35;
    }

    .vs {
      font-weight: 900;
      color: var(--soft);
      font-size: 0.8rem;
      letter-spacing: 0.24em;
      text-transform: uppercase;
    }

    .bottom-grid {
      display: grid;
      grid-template-columns: 1.15fr 0.85fr;
      gap: 18px;
    }

    .info-panel,
    .cta-panel {
      padding: 28px;
    }

    .info-panel h2,
    .cta-panel h3 {
      margin: 10px 0 0;
      font-size: clamp(1.8rem, 4vw, 2.7rem);
      line-height: 1.05;
      text-transform: uppercase;
    }

    .info-panel p,
    .cta-panel p {
      margin: 18px 0 0;
      color: var(--muted);
      line-height: 1.8;
    }

    .footer {
      padding: 28px 0 48px;
      color: var(--soft);
      font-size: 0.92rem;
      text-align: center;
    }

    .reveal {
      opacity: 0;
      transform: translateY(18px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }

    .reveal.is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    @media (max-width: 980px) {
      .hero-grid,
      .bottom-grid,
      .highlights-grid,
      .match-grid {
        grid-template-columns: 1fr;
      }

      .detail-grid {
        grid-template-columns: 1fr 1fr;
      }

      .section-head {
        align-items: start;
        flex-direction: column;
      }
    }

    @media (max-width: 720px) {
      .topbar-inner {
        min-height: auto;
        padding: 14px 0;
        flex-direction: column;
        align-items: flex-start;
      }

      .nav {
        width: 100%;
        overflow-x: auto;
        padding-bottom: 2px;
        flex-wrap: nowrap;
      }

      .hero {
        padding-top: 36px;
      }

      .detail-grid,
      .versus {
        grid-template-columns: 1fr;
      }

      .versus {
        gap: 10px;
      }

      .vs {
        justify-self: center;
      }

      .hero-actions {
        flex-direction: column;
      }

      .btn {
        width: 100%;
      }

      .container {
        width: min(calc(100% - 20px), var(--max));
      }
    }
  </style>
</head>
<body>
  <header class="topbar">
    <div class="container topbar-inner">
      <a href="#top" class="brand">
        <span class="brand-badge">WM</span>
        <span>WrestleMania 42</span>
      </a>
      <nav class="nav" aria-label="Page sections">
        <a href="#overview">Overview</a>
        <a href="#highlights">Highlights</a>
        <a href="#matches">Matches</a>
        <a href="#experience">Experience</a>
      </nav>
    </div>
  </header>

  <main id="top">
    <section class="hero" id="overview">
      <div class="container hero-grid">
        <div class="reveal">
          <div class="eyebrow">April 2026 • Las Vegas</div>
          <h1>WrestleMania <span class="accent">42</span></h1>
          <p class="lead">
            The Showcase of the Immortals returns with championship stakes, iconic entrances,
            dream match energy, and a stadium atmosphere built to feel absolutely massive.
          </p>
          <div class="hero-actions">
            <a class="btn btn-primary" href="#matches">Explore Match Card</a>
            <a class="btn btn-secondary" href="#experience">Event Experience</a>
          </div>
        </div>

        <aside class="hero-card reveal" aria-label="Event details card">
          <div class="hero-card-top">
            <div>
              <p>Headline Event</p>
              <h2 style="margin:10px 0 0; font-size: 2rem; line-height:1.05; text-transform: uppercase;">Night One + Night Two</h2>
            </div>
            <div class="live-pill">Live</div>
          </div>

          <div class="detail-grid">
            <div class="detail-box">
              <p class="label">Venue</p>
              <p class="value">Allegiant Stadium</p>
            </div>
            <div class="detail-box">
              <p class="label">City</p>
              <p class="value">Las Vegas, Nevada</p>
            </div>
            <div class="detail-box">
              <p class="label">Format</p>
              <p class="value">Two-Night Spectacle</p>
            </div>
            <div class="detail-box">
              <p class="label">Broadcast</p>
              <p class="value">Premium Live Event</p>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <section class="section" id="highlights">
      <div class="container">
        <div class="highlights-grid">
          <article class="highlight-card reveal">
            <div class="highlight-bar"></div>
            <p>Two nights of stadium-scale spectacle with a presentation built for maximum hype.</p>
          </article>
          <article class="highlight-card reveal">
            <div class="highlight-bar"></div>
            <p>Championship clashes, grudge matches, and crossover-level star power across the weekend.</p>
          </article>
          <article class="highlight-card reveal">
            <div class="highlight-bar"></div>
            <p>Fan events, merch drops, legends appearances, and all the big-weekend energy around the city.</p>
          </article>
          <article class="highlight-card reveal">
            <div class="highlight-bar"></div>
            <p>A premium event page structure you can easily turn into a preview site, promo page, or fan guide.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section" id="matches">
      <div class="container">
        <div class="section-head reveal">
          <div>
            <div class="eyebrow">Projected Card</div>
            <h2>Featured Matches</h2>
          </div>
          <p>
            These are sample matches so the page feels alive right away. Swap them with the real card,
            night split, or storylines whenever you want.
          </p>
        </div>

        <div class="match-grid">
          <article class="match-card reveal">
            <div class="match-top">
              <div class="tag">Main Event</div>
              <div class="line"></div>
            </div>
            <h3>Undisputed Championship</h3>
            <div class="versus">
              <div class="competitor">Roman Reigns</div>
              <div class="vs">vs</div>
              <div class="competitor">Cody Rhodes</div>
            </div>
          </article>

          <article class="match-card reveal">
            <div class="match-top">
              <div class="tag">Co-Main Event</div>
              <div class="line"></div>
            </div>
            <h3>Women’s World Championship</h3>
            <div class="versus">
              <div class="competitor">Rhea Ripley</div>
              <div class="vs">vs</div>
              <div class="competitor">Bianca Belair</div>
            </div>
          </article>

          <article class="match-card reveal">
            <div class="match-top">
              <div class="tag">Grudge Match</div>
              <div class="line"></div>
            </div>
            <h3>Tag Team Showcase</h3>
            <div class="versus">
              <div class="competitor">The Usos</div>
              <div class="vs">vs</div>
              <div class="competitor">DIY</div>
            </div>
          </article>

          <article class="match-card reveal">
            <div class="match-top">
              <div class="tag">Title Match</div>
              <div class="line"></div>
            </div>
            <h3>Intercontinental Championship</h3>
            <div class="versus">
              <div class="competitor">Gunther</div>
              <div class="vs">vs</div>
              <div class="competitor">LA Knight</div>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="section" id="experience">
      <div class="container bottom-grid">
        <article class="info-panel reveal">
          <div class="eyebrow">Why it matters</div>
          <h2>Bigger than a wrestling show</h2>
          <p>
            WrestleMania is part live event, part pop-culture spectacle, part mythology machine.
            This page is designed to feel like a premium event landing page with strong hierarchy,
            dramatic visuals, and fast-scanning sections that keep the spotlight on hype.
          </p>
        </article>

        <aside class="cta-panel reveal">
          <div class="eyebrow">Next move</div>
          <h3>Turn this into a real fan page</h3>
          <p>
            Replace the placeholder copy, update the matches, wire up buttons, and add media,
            countdowns, or a night-by-night layout if you want to take it further.
          </p>
          <button class="btn btn-primary" id="hypeButton" style="margin-top: 24px; width: 100%;">Watch the Hype</button>
        </aside>
      </div>
    </section>
  </main>

  <footer class="footer container">
    Built as a single-file HTML/CSS/JS WrestleMania 42 webpage template.
  </footer>

  <script>
    const reveals = document.querySelectorAll('.reveal');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.14
    });

    reveals.forEach((el) => observer.observe(el));

    const hypeButton = document.getElementById('hypeButton');
    hypeButton.addEventListener('click', () => {
      alert('This is a placeholder CTA. You can wire this button to a trailer, ticket page, or custom modal.');
    });
  </script>
</body>
</html>
